# תלויות — משוחזרות מ-package.json עם npm install, אין סיבה שיישבו בהיסטוריה
node_modules/

# תוצרי בנייה — נוצרים מחדש בכל npm run build
dist/

# מטמון הדפלוי של Firebase CLI — כלי מקומי, לא חלק מהאפליקציה
.firebase/

# תיקיות כלים אישיות — הגדרות של סביבת הפיתוח שלי, לא של הפרויקט
.claude/
.idea/
.vscode/

# קבצי סביבה מקומיים — לעולם לא עולים
*.local

# לוגים
*.log
