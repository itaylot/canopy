# תלויות — משוחזרות מ-package.json עם npm install, אין סיבה שיישבו בהיסטוריה
node_modules/

# תוצרי בנייה — נוצרים מחדש בכל npm run build
dist/

# מטמון הדפלוי של Firebase CLI — כלי מקומי, לא חלק מהאפליקציה
.firebase/

# תיקיות כלים אישיות — הגדרות של סביבת הפיתוח שלי, לא של הפרויקט
.claude/
.idea/
.vscode/

# קבצי סביבה מקומיים — לעולם לא עולים
*.local

# לוגים
*.log

# קבצים אישיים - לעולם לא נדחפים ולא נפרסים
private/

# כל מה שיושב ב-public/ מתפרסם אוטומטית לאינטרנט ולריפו. חלון השמירה של
# הדפדפן נוטה להציע את התיקייה הזאת כברירת מחדל, וכך כבר דלפו לכאן מסמכים
# אישיים וחומרי לימוד. מסמכים לא שייכים ל-public/ בשום מקרה - לכן הם חסומים
# כאן, וגם ב-firebase.json כדי שלא ידלפו דרך דפלוי.
public/*.pdf
public/*.docx
public/*.xlsx
public/*.pptx
